{%- liquid
  assign hues = 'Electric:248,Azure:236,Indigo:288' | split: ','
  assign hue = 248
  for pair in hues
    assign kv = pair | split: ':'
    if kv[0] == section.settings.accent_color
      assign hue = kv[1]
    endif
  endfor
-%}

<div
  class="bb bb-cart{% if section.settings.dark %} dark{% endif %}{% unless section.settings.use_volt %} no-volt{% endunless %}"
  data-font="{{ section.settings.headline_font }}"
  style="--blue-h:{{ hue }};"
  data-bb-cart
>
  <section class="cart">
    <div class="bb-wrap">
      <h1 class="display cart-title">{{ section.settings.heading }}</h1>

      {%- if cart.item_count == 0 -%}
        <div class="cart-empty">
          <div class="ic">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 8h12l-1.2 12.2a1 1 0 0 1-1 .8H8.2a1 1 0 0 1-1-.8z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></svg>
          </div>
          <h2>Your cart is empty</h2>
          <p>Find your speed and add a tube to get started.</p>
          <a class="btn btn-blue" href="{{ section.settings.empty_link | default: routes.all_products_collection_url }}">{{ section.settings.empty_button }}</a>
        </div>
      {%- else -%}
        <form action="{{ routes.cart_url }}" method="post" class="cart-grid">
          <div class="cart-lines">
            {%- for item in cart.items -%}
              <div class="cart-line{% if item.line_level_discount_allocations.size > 0 %} has-discount{% endif %}">
                <a class="thumb" href="{{ item.url }}">
                  {%- if item.image -%}
                    {%- assign line_alt = item.title | escape -%}
                    {{ item.image | image_url: width: 160 | image_tag: alt: line_alt, loading: 'lazy', widths: '80, 160', sizes: '72px' }}
                  {%- endif -%}
                </a>

                <div class="line-main">
                  <a class="nm" href="{{ item.url }}">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <div class="mt">{{ item.variant.title }}</div>
                  {%- endunless -%}
                  {%- for prop in item.properties -%}
                    {%- if prop.last != blank and prop.first != '_' -%}
                      <div class="mt">{{ prop.first }}: {{ prop.last }}</div>
                    {%- endif -%}
                  {%- endfor -%}
                  {%- for alloc in item.line_level_discount_allocations -%}
                    <div class="disc">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>
                      {{ alloc.discount_application.title }} (&minus;{{ alloc.amount | money }})
                    </div>
                  {%- endfor -%}

                  <div class="cart-qty">
                    <button type="button" data-bb-cart-step="-1" data-line="{{ forloop.index }}" data-qty="{{ item.quantity }}" aria-label="Decrease quantity">&minus;</button>
                    <span>{{ item.quantity }}</span>
                    <button type="button" data-bb-cart-step="1" data-line="{{ forloop.index }}" data-qty="{{ item.quantity }}" aria-label="Increase quantity">+</button>
                  </div>
                </div>

                <div class="line-right">
                  <div class="prices">
                    <div class="price">{{ item.final_line_price | money }}</div>
                    {%- if item.original_line_price > item.final_line_price -%}
                      <div class="was">{{ item.original_line_price | money }}</div>
                    {%- endif -%}
                    {%- if item.quantity > 1 -%}
                      <div class="each">{{ item.final_price | money }} each</div>
                    {%- endif -%}
                  </div>
                  <button type="button" class="rm" data-bb-cart-remove data-line="{{ forloop.index }}">Remove</button>
                </div>
              </div>
            {%- endfor -%}
          </div>

          <aside class="cart-summary">
            <h3>Summary</h3>
            <div class="row"><span>Subtotal</span><span>{{ cart.items_subtotal_price | money }}</span></div>
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              {%- for discount in cart.cart_level_discount_applications -%}
                <div class="row save"><span>{{ discount.title }}</span><span>&minus;{{ discount.total_allocated_amount | money }}</span></div>
              {%- endfor -%}
            {%- endif -%}
            <div class="row"><span>Shipping</span><span>Calculated at checkout</span></div>
            <div class="row total"><span>Total</span><span class="v">{{ cart.total_price | money }}</span></div>

            {%- if section.settings.show_note -%}
              <label class="note-lab" for="bb-cart-note">Order note</label>
              <textarea id="bb-cart-note" name="note" class="cart-note" placeholder="Notes, club name, delivery instructions…">{{ cart.note }}</textarea>
            {%- endif -%}

            <button type="submit" name="checkout" class="btn btn-primary checkout">Checkout · {{ cart.total_price | money }} <span class="arw">&rarr;</span></button>
            <a class="continue" href="{{ section.settings.empty_link | default: routes.all_products_collection_url }}">Continue shopping</a>
            <p class="ship-note">{{ section.settings.footer_note }}</p>
          </aside>
        </form>
      {%- endif -%}
    </div>
  </section>
</div>

<script src="{{ 'bb-cart.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
  .bb-cart .cart { background: var(--section-bg); color: var(--section-fg); min-height: 70vh; padding: 128px 0 110px; }
  .bb-cart .cart-title { font-size: clamp(40px, 6vw, 80px); margin-bottom: 40px; }
  .bb-cart.bb-cart-busy { opacity: 0.55; pointer-events: none; transition: opacity 0.15s; }

  .bb-cart .cart-grid { display: grid; grid-template-columns: 1fr 360px; gap: 48px; align-items: start; }
  @media (max-width: 900px) { .bb-cart .cart-grid { grid-template-columns: 1fr; gap: 32px; } }

  .bb-cart .cart-line { display: grid; grid-template-columns: 84px 1fr auto; gap: 18px; padding: 24px 0; border-bottom: 1px solid var(--section-line); }
  .bb-cart .cart-line .thumb { width: 84px; height: 84px; border-radius: 8px; overflow: hidden; background: #0b1430; display: block; }
  .bb-cart .cart-line .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .bb-cart .line-main .nm { font-weight: 700; font-size: 16px; line-height: 1.3; display: block; }
  .bb-cart .line-main .nm:hover { color: var(--blue); }
  .bb-cart .line-main .mt { font-size: 13px; color: var(--section-dim); margin-top: 4px; letter-spacing: 0.02em; }
  .bb-cart .line-main .disc { display: inline-flex; align-items: center; gap: 5px; margin-top: 7px; font-size: 12px; font-weight: 800; color: #1f8a5b; text-transform: uppercase; letter-spacing: 0.04em; }
  .bb-cart .cart-qty { display: inline-flex; align-items: center; border: 1.5px solid var(--section-line); border-radius: 6px; margin-top: 14px; background: var(--section-card); }
  .bb-cart .cart-qty button { width: 36px; height: 36px; font-size: 17px; color: var(--section-fg); }
  .bb-cart .cart-qty button:hover { color: var(--blue); }
  .bb-cart .cart-qty span { min-width: 38px; text-align: center; font-weight: 700; font-size: 15px; }

  .bb-cart .line-right { display: flex; flex-direction: column; align-items: flex-end; justify-content: space-between; gap: 10px; }
  .bb-cart .line-right .price { font-family: var(--font-display); font-weight: 800; font-size: 18px; text-align: right; }
  .bb-cart .line-right .was { font-size: 13px; color: var(--section-dim); text-decoration: line-through; text-align: right; }
  .bb-cart .line-right .each { font-size: 12px; color: var(--section-dim); text-align: right; margin-top: 2px; }
  .bb-cart .line-right .rm { font-size: 12px; color: var(--section-dim); }
  .bb-cart .line-right .rm:hover { color: #d9483b; }

  .bb-cart .cart-summary { background: var(--section-card); border: 1px solid var(--section-line); border-radius: 12px; padding: 28px; position: sticky; top: 100px; }
  .bb-cart .cart-summary h3 { font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--section-dim); margin-bottom: 18px; }
  .bb-cart .cart-summary .row { display: flex; justify-content: space-between; align-items: center; font-size: 14px; margin-bottom: 10px; color: var(--section-dim); }
  .bb-cart .cart-summary .row.save { color: #1f8a5b; font-weight: 700; }
  .bb-cart .cart-summary .row.total { font-size: 18px; color: var(--section-fg); font-weight: 800; margin: 16px 0 4px; padding-top: 16px; border-top: 1px solid var(--section-line); }
  .bb-cart .cart-summary .row.total .v { font-family: var(--font-display); font-size: 26px; }
  .bb-cart .note-lab { display: block; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--section-dim); margin: 18px 0 8px; }
  .bb-cart .cart-note { width: 100%; min-height: 70px; background: var(--section-bg); border: 1.5px solid var(--section-line); border-radius: 6px; padding: 12px; color: var(--section-fg); font-family: inherit; font-size: 14px; resize: vertical; }
  .bb-cart .checkout { width: 100%; justify-content: center; margin-top: 18px; }
  .bb-cart .continue { display: block; text-align: center; margin-top: 14px; font-size: 14px; font-weight: 600; color: var(--blue); }
  .bb-cart .continue:hover { text-decoration: underline; }
  .bb-cart .ship-note { font-size: 12px; color: var(--section-dim); text-align: center; margin-top: 14px; }

  .bb-cart .cart-empty { text-align: center; padding: 60px 20px 80px; display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .bb-cart .cart-empty .ic { width: 72px; height: 72px; border-radius: 50%; background: color-mix(in srgb, var(--blue) 12%, transparent); color: var(--blue); display: grid; place-items: center; margin-bottom: 8px; }
  .bb-cart .cart-empty h2 { font-size: 26px; }
  .bb-cart .cart-empty p { color: var(--section-dim); font-size: 15px; }
  .bb-cart .cart-empty .btn { margin-top: 16px; }
{% endstylesheet %}

{% schema %}
{
  "name": "BB Cart",
  "tag": "section",
  "class": "bb-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your cart" },
    { "type": "checkbox", "id": "show_note", "label": "Show order note field", "default": true },
    { "type": "text", "id": "footer_note", "label": "Footer note", "default": "Taxes and shipping calculated at checkout · 48hr dispatch" },
    { "type": "text", "id": "empty_button", "label": "Empty-cart button", "default": "Shop shuttlecocks" },
    { "type": "url", "id": "empty_link", "label": "Shop link", "info": "Defaults to all products." },
    { "type": "header", "content": "Style" },
    { "type": "select", "id": "accent_color", "label": "Accent color", "options": [{ "value": "Electric", "label": "Electric" }, { "value": "Azure", "label": "Azure" }, { "value": "Indigo", "label": "Indigo" }], "default": "Electric" },
    { "type": "select", "id": "headline_font", "label": "Headline font", "options": [{ "value": "Expanded", "label": "Archivo Expanded" }, { "value": "Anton", "label": "Anton" }, { "value": "Oswald", "label": "Oswald" }], "default": "Expanded" },
    { "type": "checkbox", "id": "dark", "label": "Dark background", "default": false },
    { "type": "checkbox", "id": "use_volt", "label": "Volt accent", "default": true }
  ]
}
{% endschema %}

